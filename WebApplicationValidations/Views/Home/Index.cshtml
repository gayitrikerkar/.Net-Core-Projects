@model Student;
@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>

<div class="container">
    <div class="row">
    <div class="col-4-sm">
        <form asp-action="Index" asp-controller="Home" method="post">
            <input asp-for="RollNo" placeholder="Enter RollNo" class="form-control"/><br />
                <span asp-validation-for="RollNo" class="text-danger"></span><br />

                <input asp-for="Name" placeholder="Enter name" class="form-control" /><br />
                <span asp-validation-for="Name" class="text-danger"></span><br />

                <input asp-for="Age" placeholder="Enter Age" class="form-control" /><br />
                <span asp-validation-for="Age" class="text-danger"></span><br />

                <input asp-for="Email" placeholder="Enter Email" class="form-control" /><br />
                <span asp-validation-for="Email" class="text-danger"></span><br />

                <input asp-for="Password" placeholder="Enter Password" class="form-control" /><br />
                <span asp-validation-for="Password" class="text-danger"></span><br />

                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" placeholder="Enter ConfirmPassword" class="form-control" /><br />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span><br />

                <input asp-for="WebsiteURl" placeholder="Enter WebsiteURl" class="form-control" /><br />
                <span asp-validation-for="WebsiteURl" class="text-danger"></span><br />

                <input asp-for="Address1" placeholder="Enter Address1" class="form-control" /><br />
                <span asp-validation-for="Address1" class="text-danger"></span><br />

                <input asp-for="Address2" placeholder="Enter Address2" class="form-control" /><br />
                <span asp-validation-for="Address2" class="text-danger"></span><br />

                <input type="submit" value="submit" class="btn btn-outline-primary"/>
            </form>

        </div>
    </div>
</div>