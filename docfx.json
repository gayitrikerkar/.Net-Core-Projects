{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "files": ["**/*.csproj"],
          "exclude": ["**/*test*.csproj"]
        }
      ],
      "dest": "Doc/api",
      "includePrivateMembers": true
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "Doc/build/**/*",
          "azure-pipelines.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "**/*.{png, txt}"
        ]
      }
    ],
    "output": "Doc/build/_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "Checkboxes Docs",
      "_appTitle": "Checkboxes Docs",
      "_appFooter": "© Copyright 2026, ENG-Team-104.",
      "_enableSearch": true,
      "pdf": false
    }
  }
}