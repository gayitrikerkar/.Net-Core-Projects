@model IEnumerable<PartialViews.Models.Products>

@{
    ViewData["Title"] = "Products";
}

<h1>Products</h1>

<div class="container">
<div class="row">
@foreach (var item in Model) 
{
        <div class="col-md-4">
                <partial name="_ProductsView" model="item"/>
        </div>
}
</div>
</div>
