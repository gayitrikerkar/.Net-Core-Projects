@page "/students/delete"
@using Microsoft.EntityFrameworkCore
@using BlazorServerApp.Models
@inject IDbContextFactory<BlazorServerApp.Data.BlazorServerAppContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>Students</h2>
    <hr />
    @if (students is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@students.Name</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Address</dt>
            <dd class="col-sm-10">@students.Address</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">City</dt>
            <dd class="col-sm-10">@students.City</dd>
        </dl>
        <EditForm method="post" Model="students" OnValidSubmit="DeleteStudents" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(students is null)">Delete</button> |
            <a href="/students" class="btn btn-secondary">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Students? students;

    [SupplyParameterFromQuery]
    private int RollNo { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        students = await context.Students.FirstOrDefaultAsync(m => m.RollNo == RollNo);

        if (students is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteStudents()
    {
        using var context = DbFactory.CreateDbContext();
        context.Students.Remove(students!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/students");
    }
}
