@page "/teachers/delete"
@using Microsoft.EntityFrameworkCore
@using BlazorServerAppCode.Models
@inject IDbContextFactory<BlazorServerAppCode.Models.StudentsContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>Teachers</h2>
    <hr />
    @if (teachers is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@teachers.Name</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Age</dt>
            <dd class="col-sm-10">@teachers.Age</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Gender</dt>
            <dd class="col-sm-10">@teachers.Gender</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">City</dt>
            <dd class="col-sm-10">@teachers.City</dd>
        </dl>
        <EditForm method="post" Model="teachers" OnValidSubmit="DeleteTeachers" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(teachers is null)">Delete</button> |
            <a href="/teachers" class="btn btn-secondary">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Teachers? teachers;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        teachers = await context.Teacher.FirstOrDefaultAsync(m => m.Id == Id);

        if (teachers is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteTeachers()
    {
        using var context = DbFactory.CreateDbContext();
        context.Teacher.Remove(teachers!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/teachers");
    }
}
