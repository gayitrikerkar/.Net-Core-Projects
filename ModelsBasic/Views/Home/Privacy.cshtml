@*@model StudentModel // strognlytyped for single student*@
@model IEnumerable<StudentModel>
@{
    ViewData["Title"] = "Privacy";
}

<h1>Privacy</h1>

@* 
<h1>@Model.RollNo</h1>
<h1>@Model.Name</h1>
<h1>@Model.Standard</h1> *@

@{
    foreach(var item in Model)
    {
        <h2>@item.RollNo</h2>
        <h2>@item.Name</h2>
        <h2>@item.Standard</h2>
    }
}