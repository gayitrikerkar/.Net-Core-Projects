@page "/students/details"
@using Microsoft.EntityFrameworkCore
@using BlazorServerAppTest.Models
@inject IDbContextFactory<BlazorServerAppTest.Data.BlazorServerAppTestContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>Students</h2>
    <hr />
    @if (students is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@students.Name</dd>
            <dt class="col-sm-2">City</dt>
            <dd class="col-sm-10">@students.City</dd>
            <dt class="col-sm-2">Age</dt>
            <dd class="col-sm-10">@students.Age</dd
                 <dt class="col-sm-2">HasSubmitted</dt>
            <dd class="col-sm-10">@students.HasSubmitted</dd>
           @*  <dt class="col-sm-2">Subject</dt>
            <dd class="col-sm-10">@students.Subject</dd> *@
        </dl>
        <div>
            <a href="@($"/students/edit?rollno={students.RollNo}")">Edit</a> |
            <a href="@($"/students")">Back to List</a>
        </div>
    }
</div>

@code {
    private Students? students;

    [SupplyParameterFromQuery]
    private int RollNo { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        students = await context.Students.FirstOrDefaultAsync(m => m.RollNo == RollNo);

        if (students is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}
