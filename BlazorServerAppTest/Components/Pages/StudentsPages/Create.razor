     private async Task AddStudents()
    {
        students.checkboxMod = new CheckboxModel()
            {
                checkBoxes = new List<CheckBoxOption>
                        {
                            new CheckBoxOption()
                            {
                                IsChecked = true,
                                Text="Science",
                                Value="Science"
                            },
                             new CheckBoxOption()
                            {
                                IsChecked = true,
                                Text="Maths",
                                Value="Maths"
                            },
                            new CheckBoxOption()
                            {
                                IsChecked = true,
                                Text="History",
                                Value="History"
                            }
                        }
            };

        using var context = DbFactory.CreateDbContext();
        context.Remove("Subject");
        context.Remove("checkboxMod");
        if (students.SubjectsList.Count > 0)
        {
            var data = students.SubjectsList;
            if (data != null)
            {
                foreach (var i in data)
                {
                    Students s1 = new Students()
                    {
                        Name = students.Name,
                        City=students.City,
                        Age=students.Age,
                        HasSubmitted=students.HasSubmitted,
                        Subject = i.ToString(),
                    };
                    context.Students.Add(s1);
                    context.SaveChanges();

                }
            }
        }
        // context.Students.Add(students);
        // await context.SaveChangesAsync();
        // NavigationManager.NavigateTo("/students");
    }
}
